# Скопировать в .env.local и заполнить перед запуском
# На Vercel — добавить переменные через Dashboard → Settings → Environment Variables

# ─── Telegram ────────────────────────────────────────────────────────────────
# Используется в /api/audit для отправки заявок в Telegram
# Формат: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
# Получить токен: @BotFather в Telegram
# Получить chat_id: написать боту → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_WEBHOOK_URL=
